# ════════════════════════════
#  CinePRO — gitignore
# ════════════════════════════

# OS junk
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Editors
.vscode/
.idea/

# Node / npm
node_modules/
npm-debug.log*
yarn-error.log
.npm
.eslintcache

# Electron / electron-builder build outputs
desktop-app/dist/
desktop-app/out/

# Installer build artifacts (NÃO commitar binários — vão via GitHub Actions Releases)
installer/dist/*.pkg
installer/dist/*.dmg
installer/dist/*.exe
installer/dist/*.blockmap
installer/dist/mac/
installer/dist/mac-arm64/
installer/dist/mac-x64/
installer/dist/win-unpacked/
installer/dist/builder-debug.yml
installer/dist/builder-effective-config.yaml
installer/mac/.build/
installer/.icons-tmp/

# Firebase
firebase/functions/node_modules/
firebase/functions/.runtimeconfig.json
firebase/.firebase/
firebase-debug.log

# Logs
*.log

# Tmp
*.tmp
.tmp/

# Misc
.python-version
__pycache__/
*.pyc

# Claude Code local config
.claude/

# Drive audit — credentials e dumps grandes (não commitar)
audit/node_modules/
audit/oauth-client.json
audit/.oauth-token.json
audit/trash-logs/
audit/drive-audit-full.csv
audit/drive-audit-trash.csv
audit/drive-delete-list.csv

# Manifest builder — só não commita node_modules; o manifest.json em si VAI commitar
manifest/node_modules/

# Bundle builder — ~400MB de assets; NÃO commitar. CI baixa fresh a cada release.
bundle/node_modules/
bundle/dist/
audit/perm-fix-logs/
